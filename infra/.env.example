# Copy this file to .env and fill in real values before starting the stack.
# Generate strong passwords with: openssl rand -base64 24

# --- Deployment mode ---
# standalone (default): leave PG_HOST unset — the bundled `db` container is
#   used (start with: docker compose --profile standalone up -d --build)
# shared: point PG_HOST at your shared TimescaleDB cluster's address; the
#   bundled DB never starts (start with: docker compose up -d --build)
#PG_HOST=your-cluster-host

# Superuser password for the bundled DB (standalone mode). The migration
# runner also uses it by default; in shared mode set PG_MIGRATE_USER /
# PG_MIGRATE_PASSWORD to a role on the cluster that may CREATE ROLE
# (first run only — afterwards iaq_owner credentials suffice).
POSTGRES_SUPER_PW=change-me-use-openssl-rand-base64-24
#PG_MIGRATE_USER=postgres
#PG_MIGRATE_PASSWORD=

# Per-role passwords (created by the first migration; least privilege:
# iaq_owner = DDL/migrations, iaq_rw = ingest writers, iaq_ro = Grafana)
IAQ_OWNER_PW=change-me-use-openssl-rand-base64-24
IAQ_RW_PW=change-me-use-openssl-rand-base64-24
IAQ_RO_PW=change-me-use-openssl-rand-base64-24

# Grafana
GRAFANA_ADMIN_PASSWORD=change-me-use-openssl-rand-base64-24

# MQTT broker
MQTT_USER=iaq
MQTT_PASSWORD=change-me-use-openssl-rand-base64-24

# PurpleAir (outdoor sensor) — get keys from develop.purpleair.com
PURPLEAIR_API_KEY=your-account-api-key-here
PURPLEAIR_SENSOR_INDEX=your-sensor-index-here
PURPLEAIR_READ_KEY=your-per-sensor-read-key-here
